# ─── AWS deployment environment variables ────────────────────────────────────
# These are injected into containers by ECS at runtime.
# Sensitive values (marked with *) must be stored in AWS Secrets Manager at
#   /polymarket/{dev|prod}/env
# and referenced by the task definition — never put them in this file.
#
# Non-sensitive values are hardcoded in the task definition JSON
# (infra/task-definition-{dev|prod}.json).

# ─── Runtime mode ────────────────────────────────────────────────────────────
ENV=aws

# ─── Polymarket ──────────────────────────────────────────────────────────────
PM_WS_URL=wss://ws-subscriptions-clob.polymarket.com
PM_SLUG_PREFIX=btc-updown-5m
CANDLE_INTERVAL_MINUTES=5

# ─── Storage ─────────────────────────────────────────────────────────────────
LOCAL_DATA_DIR=/data
AWS_BUCKET=polymarket-ml-prod      # polymarket-ml-dev for dev
AWS_REGION=eu-central-1

# ─── Collector tuning ────────────────────────────────────────────────────────
TICK_INTERVAL_SECONDS=1.0
EXPORT_INTERVAL_MINUTES=5

# ─── Trade engine ─────────────────────────────────────────────────────────────
PM_FEE=0.02

# ─── Secrets (store in AWS Secrets Manager, not here) ────────────────────────
# Create with:
#   aws secretsmanager create-secret \
#     --name /polymarket/prod/env \
#     --secret-string '{"PM_API_KEY":"..."}' \
#     --region eu-central-1
#
# *PM_API_KEY=          # Polymarket API key (if required by authenticated endpoints)

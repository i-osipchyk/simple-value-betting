# ─── Environment ────────────────────────────────────────────────────────────
ENV=local                # local | aws

# ─── Polymarket ─────────────────────────────────────────────────────────────
PM_WS_URL=wss://ws-subscriptions-clob.polymarket.com

# Slug prefix for auto-discovering the current candle's market from the Gamma API.
# Full slug = "{PM_SLUG_PREFIX}-{unix_timestamp_of_candle_start}"
# e.g. "btc-updown-15m-1716000000"
# Market ID and token IDs are fetched automatically — no manual config needed.
PM_SLUG_PREFIX=btc-updown-5m
CANDLE_INTERVAL_MINUTES=5

# ─── Local storage (ENV=local) ───────────────────────────────────────────────
LOCAL_DATA_DIR=/data

# ─── AWS (ENV=aws) ───────────────────────────────────────────────────────────
AWS_BUCKET=polymarket-ml-prod
AWS_REGION=eu-central-1

# ─── Collector tuning ────────────────────────────────────────────────────────
EXPORT_INTERVAL_MINUTES=5
TICK_INTERVAL_SECONDS=1.0

# WebSocket reconnection backoff (seconds)
RECONNECT_BASE_DELAY=1.0
RECONNECT_MAX_DELAY=60.0

# ─── Model training ─────────────────────────────────────────────────────────
TRAIN_INTERVAL_HOURS=24
MIN_TRAINING_ROWS=500

# ─── Prediction ─────────────────────────────────────────────────────────────
MIN_EDGE_THRESHOLD=0.05

# ─── Polymarket fee (for P&L simulation) ────────────────────────────────────
PM_FEE=0.02
